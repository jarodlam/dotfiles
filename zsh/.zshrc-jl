# Layered on top of system config.
# Add to top of system ~/.zshrc:
#   source ~/.zshrc-jl

# Enable zsh completion system
autoload -Uz compinit
autoload -Uz bashcompinit
compinit
bashcompinit

# zsh vi mode
bindkey -v

# Option-key bindings for word navigation and deletion.
#
# With macos-option-as-alt enabled in ghostty, pressing option+key sends an
# ESC-prefixed escape sequence. Without explicit bindings here, zsh's low
# KEYTIMEOUT causes the bare ESC to be interpreted as "enter vi normal mode"
# before the rest of the sequence arrives. Binding them explicitly tells zsh
# to recognize the full sequence immediately.
#
# Ghostty keybinds (alt+arrow_left=esc:b, alt+arrow_right=esc:f) send the
# sequences \eb and \ef respectively. The \e[1;3D / \e[1;3C variants are
# the standard terminal escape sequences for Alt+Arrow that some apps send.
#
# viins = vi insert mode (normal typing), vicmd = vi normal/command mode.
bindkey -M viins '\e[1;3D' backward-word       # Option+Left       - move cursor one word left
bindkey -M viins '\e[1;3C' forward-word         # Option+Right      - move cursor one word right
bindkey -M viins '\eb' backward-word            # Option+Left       - sent by ghostty keybind
bindkey -M viins '\ef' forward-word             # Option+Right      - sent by ghostty keybind
bindkey -M viins '\e\x7f' backward-kill-word    # Option+Backspace  - delete one word left
bindkey -M viins '\ed' kill-word                # Option+d          - delete one word right
bindkey -M vicmd '\e[1;3D' backward-word        # Option+Left       - in vi command mode
bindkey -M vicmd '\e[1;3C' forward-word         # Option+Right      - in vi command mode
bindkey -M vicmd '\eb' backward-word            # Option+Left       - in vi command mode
bindkey -M vicmd '\ef' forward-word             # Option+Right      - in vi command mode

# zsh history settings
HISTFILE=~/.zsh_history
HISTFILESIZE=10000000
HISTSIZE=10000000
SAVEHIST=500000
setopt INC_APPEND_HISTORY
setopt SHARE_HISTORY
setopt APPENDHISTORY

# zsh autocomplete dot files
setopt GLOBDOTS

# zsh disable highlight on paste
zle_highlight+=(paste:none)

# zsh syntax highlighting plugin
source ~/.config/zsh/fast-syntax-highlighting/fast-syntax-highlighting.plugin.zsh

# default editor
export VISUAL=nvim
export EDITOR=nvim

# zsh instant ESC key for vi mode
# Default is 40 (0.4 s), keep a little bit of time so we don't interrupt ESC sequences
# https://github.com/starship/starship/discussions/7104#discussioncomment-15344825
export KEYTIMEOUT=5

# starship (guard against re-source: starship wraps zle-keymap-select,
# and re-wrapping causes infinite recursion)
if [[ -z "${_starship_initialized:-}" ]]; then
  eval "$(starship init zsh)"
  _starship_initialized=1
fi

# yazi
function y() {
  local tmp="$(mktemp -t "yazi-cwd.XXXXXX")" cwd
  yazi "$@" --cwd-file="$tmp"
  IFS= read -r -d '' cwd < "$tmp"
  [ -n "$cwd" ] && [ "$cwd" != "$PWD" ] && builtin cd -- "$cwd"
  rm -f -- "$tmp"
}

# fzf
source <(fzf --zsh)

# direnv
eval "$(direnv hook zsh)"

# colour aliases
alias ls='ls --color=auto'
alias grep='grep --color=auto'
alias diff='diff --color=auto'

# common ls aliases
alias ll='ls -alFh'
alias la='ls -A'
alias l='ls -CF'

# other aliases
alias nd='(){ nix develop .#$1 -vv --command zsh }'
alias nr='ulimit -v 10485760 && nix repl'
alias lg='lazygit'
