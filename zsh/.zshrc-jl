# Layered on top of system config.
# Add to top of system ~/.zshrc:
#   source ~/.zshrc-jl

# Enable zsh completion system
autoload -Uz compinit
autoload -Uz bashcompinit
compinit
bashcompinit

# zsh vi mode
bindkey -v

# zsh history settings
HISTFILE=~/.zsh_history
HISTFILESIZE=10000000
HISTSIZE=10000000
SAVEHIST=500000
setopt INC_APPEND_HISTORY
setopt SHARE_HISTORY
setopt APPENDHISTORY

# zsh autocomplete dot files
setopt GLOBDOTS

# zsh syntax highlighting plugin
source ~/.config/zsh/fast-syntax-highlighting/fast-syntax-highlighting.plugin.zsh

# default editor
export VISUAL=nvim
export EDITOR=nvim

# zsh instant ESC key for vi mode
# Default is 40 (0.4 s), keep a little bit of time so we don't interrupt ESC sequences
# https://github.com/starship/starship/discussions/7104#discussioncomment-15344825
export KEYTIMEOUT=5

# starship (guard against re-source: starship wraps zle-keymap-select,
# and re-wrapping causes infinite recursion)
if [[ -z "${_starship_initialized:-}" ]]; then
  eval "$(starship init zsh)"
  _starship_initialized=1
fi

# yazi
function y() {
  local tmp="$(mktemp -t "yazi-cwd.XXXXXX")" cwd
  yazi "$@" --cwd-file="$tmp"
  IFS= read -r -d '' cwd < "$tmp"
  [ -n "$cwd" ] && [ "$cwd" != "$PWD" ] && builtin cd -- "$cwd"
  rm -f -- "$tmp"
}

# fzf
source <(fzf --zsh)

# direnv
eval "$(direnv hook zsh)"

# colour aliases
alias ls='ls --color=auto'
alias grep='grep --color=auto'
alias diff='diff --color=auto'

# common ls aliases
alias ll='ls -alFh'
alias la='ls -A'
alias l='ls -CF'

# other aliases
alias nd='(){ nix develop .#$1 -vv --command zsh }'
alias nr='ulimit -v 10485760 && nix repl'
alias lg='lazygit'
